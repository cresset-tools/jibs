{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MySQL Import DSL",
  "scopeName": "source.mysqlimport-dsl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#after-block" },
    { "include": "#where-clause" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#multiline-strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mysqlimport-dsl",
          "match": "#(?!\\[).*$"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.mysqlimport-dsl",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.attribute.end.mysqlimport-dsl" }
          },
          "patterns": [
            {
              "name": "keyword.control.attribute.when.mysqlimport-dsl",
              "match": "\\bwhen\\b"
            },
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "after-block": {
      "patterns": [
        {
          "name": "meta.after-block.mysqlimport-dsl",
          "begin": "\\b(after)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.after.mysqlimport-dsl" },
            "2": { "name": "punctuation.definition.block.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.block.end.mysqlimport-dsl" }
          },
          "patterns": [
            { "include": "#sql-multiline-string" },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "where-clause": {
      "patterns": [
        {
          "name": "meta.where-clause.mysqlimport-dsl",
          "begin": "\\b(where)\\s*(\")",
          "end": "\"",
          "beginCaptures": {
            "1": { "name": "keyword.other.where.mysqlimport-dsl" },
            "2": { "name": "punctuation.definition.string.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mysqlimport-dsl" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "#sql-interpolation" },
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "sql-multiline-string": {
      "patterns": [
        {
          "name": "string.quoted.triple.sql.mysqlimport-dsl",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mysqlimport-dsl" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "sql-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.mysqlimport-dsl",
          "match": "\\{\\$[a-zA-Z_][a-zA-Z0-9_]*\\}",
          "captures": {
            "0": { "name": "variable.other.mysqlimport-dsl" }
          }
        },
        {
          "name": "meta.interpolation.mysqlimport-dsl",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.mysqlimport-dsl" }
          },
          "contentName": "meta.embedded.expression.mysqlimport-dsl",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.mysqlimport-dsl",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.declaration.var.mysqlimport-dsl",
          "match": "\\bvar\\b"
        },
        {
          "name": "keyword.declaration.faker.mysqlimport-dsl",
          "match": "\\bfaker\\b"
        },
        {
          "name": "keyword.declaration.relation.mysqlimport-dsl",
          "match": "\\brelation\\b"
        },
        {
          "name": "keyword.declaration.anonymize.mysqlimport-dsl",
          "match": "\\banonymize\\b"
        },
        {
          "name": "keyword.control.exclude.mysqlimport-dsl",
          "match": "\\bexclude\\b"
        },
        {
          "name": "keyword.control.ignore.mysqlimport-dsl",
          "match": "\\bignore\\b"
        },
        {
          "name": "keyword.declaration.aggregate.mysqlimport-dsl",
          "match": "\\baggregate\\b"
        },
        {
          "name": "keyword.control.include.mysqlimport-dsl",
          "match": "\\binclude\\b"
        },
        {
          "name": "keyword.control.preserve.mysqlimport-dsl",
          "match": "\\bpreserve\\b"
        },
        {
          "name": "keyword.declaration.set.mysqlimport-dsl",
          "match": "\\bset\\b"
        },
        {
          "name": "keyword.declaration.after.mysqlimport-dsl",
          "match": "\\bafter\\b"
        },
        {
          "name": "keyword.other.root.mysqlimport-dsl",
          "match": "\\broot\\b"
        },
        {
          "name": "keyword.other.where.mysqlimport-dsl",
          "match": "\\bwhere\\b"
        },
        {
          "name": "keyword.other.order.mysqlimport-dsl",
          "match": "\\border\\b"
        },
        {
          "name": "keyword.other.by.mysqlimport-dsl",
          "match": "\\bby\\b"
        },
        {
          "name": "keyword.other.limit.mysqlimport-dsl",
          "match": "\\blimit\\b"
        },
        {
          "name": "keyword.other.match.mysqlimport-dsl",
          "match": "\\bmatch\\b"
        },
        {
          "name": "keyword.other.asc.mysqlimport-dsl",
          "match": "\\basc\\b"
        },
        {
          "name": "keyword.other.desc.mysqlimport-dsl",
          "match": "\\bdesc\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mysqlimport-dsl",
          "match": "\\b(string|int|float|bool)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mysqlimport-dsl",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mysqlimport-dsl" }
          },
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "multiline-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.mysqlimport-dsl",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mysqlimport-dsl" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.mysqlimport-dsl",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.mysqlimport-dsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.mysqlimport-dsl" }
          },
          "contentName": "meta.embedded.expression.mysqlimport-dsl",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.mysqlimport-dsl",
          "match": "\\\\[\\\\\"nt\\{]"
        }
      ]
    },
    "expressions": {
      "patterns": [
        { "include": "#variables" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#operators" },
        { "include": "#strings" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.mysqlimport-dsl",
          "match": "-?\\d+\\.\\d+"
        },
        {
          "name": "constant.numeric.integer.mysqlimport-dsl",
          "match": "-?\\d+"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.mysqlimport-dsl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "null": {
      "patterns": [
        {
          "name": "constant.language.null.mysqlimport-dsl",
          "match": "\\bnull\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.mysqlimport-dsl",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.mysqlimport-dsl",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.mysqlimport-dsl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.mysqlimport-dsl",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.mysqlimport-dsl",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.mysqlimport-dsl",
          "match": "="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.mysqlimport-dsl",
          "match": "(?<=aggregate\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.mysqlimport-dsl",
          "match": "(?<=anonymize\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.mysqlimport-dsl",
          "match": "(?<=root\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.property.mysqlimport-dsl",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\.)"
        },
        {
          "name": "variable.other.property.mysqlimport-dsl",
          "match": "(?<=\\.)\\s*[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
