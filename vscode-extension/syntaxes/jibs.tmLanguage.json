{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MySQL Import DSL",
  "scopeName": "source.jibs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#after-block" },
    { "include": "#where-clause" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#multiline-strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.jibs",
          "match": "//.*$"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.jibs",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.attribute.end.jibs" }
          },
          "patterns": [
            {
              "name": "keyword.control.attribute.when.jibs",
              "match": "\\bwhen\\b"
            },
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "after-block": {
      "patterns": [
        {
          "name": "meta.after-block.jibs",
          "begin": "\\b(after)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.after.jibs" },
            "2": { "name": "punctuation.definition.block.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.block.end.jibs" }
          },
          "patterns": [
            { "include": "#sql-multiline-string" },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "where-clause": {
      "patterns": [
        {
          "name": "meta.where-clause.jibs",
          "begin": "\\b(where)\\s*(\")",
          "end": "\"",
          "beginCaptures": {
            "1": { "name": "keyword.other.where.jibs" },
            "2": { "name": "punctuation.definition.string.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jibs" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "#sql-interpolation" },
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "sql-multiline-string": {
      "patterns": [
        {
          "name": "string.quoted.triple.sql.jibs",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jibs" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "sql-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.jibs",
          "match": "\\{\\$[a-zA-Z_][a-zA-Z0-9_]*\\}",
          "captures": {
            "0": { "name": "variable.other.jibs" }
          }
        },
        {
          "name": "meta.interpolation.jibs",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.jibs" }
          },
          "contentName": "meta.embedded.expression.jibs",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.jibs",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.declaration.var.jibs",
          "match": "\\bvar\\b"
        },
        {
          "name": "keyword.declaration.faker.jibs",
          "match": "\\bfaker\\b"
        },
        {
          "name": "keyword.declaration.relation.jibs",
          "match": "\\brelation\\b"
        },
        {
          "name": "keyword.declaration.anonymize.jibs",
          "match": "\\banonymize\\b"
        },
        {
          "name": "keyword.control.exclude.jibs",
          "match": "\\bexclude_data\\b"
        },
        {
          "name": "keyword.control.ignore.jibs",
          "match": "\\bignore_table\\b"
        },
        {
          "name": "keyword.control.ignore-relation.jibs",
          "match": "\\bignore_relation\\b"
        },
        {
          "name": "keyword.declaration.aggregate.jibs",
          "match": "\\baggregate\\b"
        },
        {
          "name": "keyword.control.include.jibs",
          "match": "\\binclude\\b"
        },
        {
          "name": "keyword.control.preserve.jibs",
          "match": "\\bpreserve\\b"
        },
        {
          "name": "keyword.declaration.set.jibs",
          "match": "\\bset\\b"
        },
        {
          "name": "keyword.declaration.after.jibs",
          "match": "\\bafter\\b"
        },
        {
          "name": "keyword.other.root.jibs",
          "match": "\\broot\\b"
        },
        {
          "name": "keyword.other.where.jibs",
          "match": "\\bwhere\\b"
        },
        {
          "name": "keyword.other.order.jibs",
          "match": "\\border\\b"
        },
        {
          "name": "keyword.other.by.jibs",
          "match": "\\bby\\b"
        },
        {
          "name": "keyword.other.limit.jibs",
          "match": "\\blimit\\b"
        },
        {
          "name": "keyword.other.full.jibs",
          "match": "\\bfull\\b"
        },
        {
          "name": "keyword.other.root-only.jibs",
          "match": "\\broot_only\\b"
        },
        {
          "name": "keyword.control.exclude.aggregate.jibs",
          "match": "(?<=\\b)exclude(?=\\s)"
        },
        {
          "name": "keyword.other.match.jibs",
          "match": "\\bmatch\\b"
        },
        {
          "name": "keyword.other.asc.jibs",
          "match": "\\basc\\b"
        },
        {
          "name": "keyword.other.desc.jibs",
          "match": "\\bdesc\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.jibs",
          "match": "\\b(string|int|float|bool)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jibs",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jibs" }
          },
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "multiline-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.jibs",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.jibs" }
          },
          "contentName": "meta.embedded.block.sql",
          "patterns": [
            { "include": "source.sql" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.jibs",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.jibs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.jibs" }
          },
          "contentName": "meta.embedded.expression.jibs",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.jibs",
          "match": "\\\\[\\\\\"nt\\{]"
        }
      ]
    },
    "expressions": {
      "patterns": [
        { "include": "#variables" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#operators" },
        { "include": "#strings" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.jibs",
          "match": "-?\\d+\\.\\d+"
        },
        {
          "name": "constant.numeric.integer.jibs",
          "match": "-?\\d+"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.jibs",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "null": {
      "patterns": [
        {
          "name": "constant.language.null.jibs",
          "match": "\\bnull\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.jibs",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.jibs",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.jibs",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.jibs",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.jibs",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.jibs",
          "match": "="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.jibs",
          "match": "(?<=aggregate\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.jibs",
          "match": "(?<=anonymize\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.jibs",
          "match": "(?<=root\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.property.jibs",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\.)"
        },
        {
          "name": "variable.other.property.jibs",
          "match": "(?<=\\.)\\s*[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
