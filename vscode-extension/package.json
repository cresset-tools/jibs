{
  "name": "jibs",
  "displayName": "Jibs - Jelle's Importer with Better Speed",
  "description": "Syntax highlighting for Jibs DSL files",
  "version": "0.1.0",
  "publisher": "jibs",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jibs",
        "aliases": [
          "Jibs",
          "jibs"
        ],
        "extensions": [
          ".jibs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jibs",
        "scopeName": "source.jibs",
        "path": "./syntaxes/jibs.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.sql": "sql"
        }
      }
    ]
  }
}
