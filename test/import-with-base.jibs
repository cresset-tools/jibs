// Test import functionality
// This imports base relations and adds aggregate-specific config

import "base-relations.jibs"

// Define an aggregate that uses the imported relations
aggregate user1_orders {
    root orders
    where "user_id = 1"
}

// Exclude audit_log (no data)
exclude_data audit_log

// Ignore sessions entirely
ignore_table sessions

// Anonymize user emails
anonymize users {
    email -> emails
    password_hash -> null
}

// Faker pool for emails
faker emails [
    "anon1@test.local",
    "anon2@test.local"
]

// Set password after import
after {
    """UPDATE users SET password_hash = '$2b$10$testpasswordhash' WHERE password_hash IS NULL"""
}
