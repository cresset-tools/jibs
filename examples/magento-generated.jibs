relation cataloginventory_stock_status.stock_id -> cataloginventory_stock.stock_id

relation catalogrule_group_website.rule_id -> catalogrule.rule_id
relation catalogrule_product.rule_id -> catalogrule.rule_id

relation quote_address.customer_address_id -> customer_address_entity.entity_id
relation sales_order_address.customer_address_id -> customer_address_entity.entity_id
relation customer_log.customer_id -> customer_entity.entity_id
relation customer_visitor.customer_id -> customer_entity.entity_id
relation gift_message.customer_id -> customer_entity.entity_id
relation login_as_customer.customer_id -> customer_entity.entity_id
relation magento_login_as_customer_log.customer_id -> customer_entity.entity_id
