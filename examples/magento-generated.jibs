relation quote.customer_id -> customer_entity.entity_id
relation quote_address.customer_id -> customer_entity.entity_id
relation rating_option_vote.customer_id -> customer_entity.entity_id
relation reporting_orders.customer_id -> customer_entity.entity_id
relation sales_order_address.customer_id -> customer_entity.entity_id
relation sales_order_grid.entity_id -> sales_order.entity_id
relation sales_order_grid.customer_id -> customer_entity.entity_id
relation sales_shipment.customer_id -> customer_entity.entity_id
relation catalogrule_group_website.customer_group_id -> customer_group.customer_group_id
relation catalogrule_product.customer_group_id -> customer_group.customer_group_id
relation catalogrule_product_price.customer_group_id -> customer_group.customer_group_id
relation customer_group_excluded_website.customer_group_id -> customer_group.customer_group_id
relation quote.customer_group_id -> customer_group.customer_group_id
relation sales_creditmemo_grid.customer_group_id -> customer_group.customer_group_id
relation sales_invoice_grid.customer_group_id -> customer_group.customer_group_id
