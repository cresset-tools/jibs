// Magento 2 (Open Source) import configuration
//
// Generated with scripts/generate-magento-jibs.py from a stock Magento 2
// schema and curated by hand. Covers the core tables every Magento 2 install
// has; regenerate against your own schema dump to pick up the tables of your
// installed third-party modules:
//
//     python3 scripts/generate-magento-jibs.py your-schema.sql > shop.jibs

// ─── Variables ───
var admin_password_hash: string = "$2y$10$placeholder"
var customer_password_hash: string = "$2y$10$placeholder"
var customer_limit: int = 10
var order_limit: int = 10
var product_limit: int = 10
var base_url: string

// ─── Faker pools for anonymization ───

faker fake_emails [
    "user{unique()}@example.test"
]

faker fake_names [
    "Alice",
    "Bob",
    "Charlie",
    "Diana",
    "Edward",
    "Fiona",
    "George",
    "Hannah",
    "Ivan",
    "Julia",
    "Kevin",
    "Laura",
    "Michael",
    "Nancy",
    "Oscar",
    "Patricia",
    "Quinn",
    "Rachel",
    "Steven",
    "Teresa"
]

faker fake_streets [
    "123 Test Street",
    "456 Demo Avenue",
    "789 Sample Road",
    "101 Example Lane",
    "202 Mock Boulevard"
]

faker fake_phones [
    "+15550100001",
    "+15550100002",
    "+15550100003",
    "+15550100004",
    "+15550100005"
]

faker fake_postcodes [
    "10001",
    "20002",
    "30003",
    "40004",
    "50005"
]

// ─── Table relations ───
// Relations tell jibs how to traverse between tables for aggregates.
// inferred = from column naming convention.

relation authorization_role.user_id -> admin_user.user_id
relation import_history.user_id -> admin_user.user_id
relation jwt_auth_revoked.user_id -> admin_user.user_id
relation magento_bulk.user_id -> admin_user.user_id
relation magento_login_as_customer_log.user_id -> admin_user.user_id
relation sales_creditmemo_comment.user_id -> admin_user.user_id
relation sales_invoice_comment.user_id -> admin_user.user_id
relation sales_shipment_comment.user_id -> admin_user.user_id

relation cataloginventory_stock_status.product_id -> catalog_product_entity.entity_id
relation catalogrule_product.product_id -> catalog_product_entity.entity_id
relation catalogrule_product_price.product_id -> catalog_product_entity.entity_id
relation downloadable_link_purchased_item.product_id -> catalog_product_entity.entity_id
relation quote_address_item.product_id -> catalog_product_entity.entity_id
relation quote_item.product_id -> catalog_product_entity.entity_id
relation quote_item_option.product_id -> catalog_product_entity.entity_id
relation sales_bestsellers_aggregated_daily.product_id -> catalog_product_entity.entity_id
relation sales_bestsellers_aggregated_monthly.product_id -> catalog_product_entity.entity_id
relation sales_bestsellers_aggregated_yearly.product_id -> catalog_product_entity.entity_id
