relation catalog_product_bundle_option_value.store_id -> store.store_id
relation design_config_grid_flat.store_id -> store.store_id
relation paypal_settlement_report_row.store_id -> store.store_id
relation quote_address_item.store_id -> store.store_id
relation sales_creditmemo_grid.store_id -> store.store_id
relation sales_invoice_grid.store_id -> store.store_id
relation sales_order_grid.store_id -> store.store_id
relation sales_sequence_meta.store_id -> store.store_id
relation sales_shipment_grid.store_id -> store.store_id
relation customer_entity.group_id -> store_group.group_id
relation customer_grid_flat.group_id -> store_group.group_id
relation design_config_grid_flat.store_group_id -> store_group.group_id
relation design_config_grid_flat.store_website_id -> store_website.website_id

relation review.entity_pk_value -> catalog_product_entity.entity_id
relation review_detail.review_id -> review.review_id
relation review_store.review_id -> review.review_id

relation customer_group.tax_class_id -> tax_class.class_id
relation customer_grid_flat.entity_id -> customer_entity.entity_id
ignore_relation sales_order_tax_item.associated_item_id -> sales_order_item.item_id
ignore_relation url_rewrite.store_id -> store.store_id

// ─── Ignored tables (not imported at all) ───
// Session, cache, changelog, and cron tables that are rebuilt automatically.
ignore_table /^cache/
ignore_table /_cl$/
ignore_table cron_schedule
ignore_table session

// ─── Schema-only tables (structure imported, no data) ───
// Index temp tables, reports, logs, and aggregated data that gets rebuilt.
exclude_data /_idx$/
exclude_data /index/
exclude_data /_tmp$/
exclude_data /_replica$/
exclude_data /_aggregated/
exclude_data /^report/
exclude_data /data_exporter/
exclude_data /^queue_/
exclude_data /^payment_services_/
exclude_data captcha_log
exclude_data customer_log
exclude_data customer_visitor
exclude_data importexport_importdata
exclude_data oauth_nonce
exclude_data oauth_token_request_log
exclude_data password_reset_request_event
exclude_data sendfriend_log
exclude_data search_query

// ─── Rebuild/temp tables ───
exclude_data /^catalogrule_product/
exclude_data /^catalogsearch_fulltext/
exclude_data /_flat$/
exclude_data /_log$/
exclude_data /_errors?$/
exclude_data /^tmp_/
exclude_data /_temp/

// ─── Magento system tables (safe to be empty for dev) ───
exclude_data admin_user_session
exclude_data adminnotification_inbox
exclude_data /^adobe_stock_/
exclude_data adobe_user_profile
exclude_data catalog_compare_list
exclude_data catalogsearch_recommendations
exclude_data import_history
exclude_data /^magento_acknowledged_bulk/
exclude_data /^magento_bulk/
exclude_data /^magento_operation/
exclude_data persistent_session
exclude_data search_synonyms

// ─── Newsletter (specific tables, not /^newsletter_/ which would catch newsletter_template) ───
exclude_data newsletter_subscriber
exclude_data newsletter_queue
exclude_data newsletter_queue_link
exclude_data newsletter_queue_store_link
exclude_data newsletter_problem

// ─── Third-party module tables ───
// Add exclude_data patterns here for your installed modules' log, queue,
// and analytics tables (payment providers, feed exporters, email marketing,
// search trackers, ...). Regenerating from your schema dump suggests these.

// ─── Full imports for reference tables ───
full review_entity, review_status
full catalog_product_link_attribute, catalog_product_link_type
full sales_order_status, sales_order_status_state
full sales_sequence_meta, sales_sequence_profile

// ─── Anonymization rules ───
// Strips PII from customer, order, and admin tables.

anonymize admin_adobe_ims_webapi {
    access_token -> null
    access_token_hash -> null
}

anonymize admin_user_session {
    ip -> null
}

anonymize adobe_user_profile {
    access_token -> null
}

anonymize customer_address_entity {
    fax -> fake_phones
    firstname -> fake_names
    lastname -> fake_names
    postcode -> fake_postcodes
    street -> fake_streets
    telephone -> fake_phones
}

anonymize customer_entity {
    email -> fake_emails
    firstname -> fake_names
    lastname -> fake_names
    password_hash -> null
    rp_token -> null
}

anonymize customer_grid_flat {
    billing_fax -> fake_phones
    billing_firstname -> fake_names
    billing_lastname -> fake_names
    billing_postcode -> fake_postcodes
    billing_street -> fake_streets
    billing_telephone -> fake_phones
    email -> fake_emails
}

anonymize email_template {
    template_sender_email -> fake_emails
}

anonymize integration {
    email -> fake_emails
}

anonymize magento_login_as_customer_log {
    customer_email -> fake_emails
}

anonymize newsletter_subscriber {
    subscriber_email -> fake_emails
}

anonymize newsletter_template {
    template_sender_email -> fake_emails
}

anonymize quote {
    customer_email -> fake_emails
    customer_firstname -> fake_names
    customer_lastname -> fake_names
    password_hash -> null
    remote_ip -> null
}

anonymize quote_address {
    email -> fake_emails
    fax -> fake_phones
    firstname -> fake_names
    lastname -> fake_names
    postcode -> fake_postcodes
    street -> fake_streets
    telephone -> fake_phones
}

anonymize rating_option_vote {
    remote_ip -> null
    remote_ip_long -> null
}

anonymize sales_creditmemo_grid {
    customer_email -> fake_emails
}

anonymize sales_invoice_grid {
    customer_email -> fake_emails
}

anonymize sales_order {
    customer_email -> fake_emails
    customer_firstname -> fake_names
    customer_lastname -> fake_names
    remote_ip -> null
    x_forwarded_for -> null
}

anonymize sales_order_address {
    email -> fake_emails
    fax -> fake_phones
    firstname -> fake_names
    lastname -> fake_names
    postcode -> fake_postcodes
    street -> fake_streets
    telephone -> fake_phones
}

anonymize sales_order_grid {
    customer_email -> fake_emails
}

anonymize sales_shipment_grid {
    customer_email -> fake_emails
}

aggregate products {
    root catalog_product_entity
    where "FALSE"
    exclude /^sales_/, /^quote/, /^customer_/, /^url_rewrite/
}

get product_by_sku (sku: string) {
    products where "sku like '{$sku}'"
}

get product_by_urlkey (urlkey: string) {
    products where "entity_id IN (SELECT entity_id FROM url_rewrite WHERE request_path = '{$urlkey}')"
}

set core_config_data {
    match path = "web/secure/base_url", scope = "default", scope_id = 0
    value = $base_url
}

set core_config_data {
    match path = "web/unsecure/base_url", scope = "default", scope_id = 0
    value = $base_url
}

after {
    """
    DELETE FROM core_config_data WHERE path = 'web/secure/base_url' AND scope <> 'default';
    DELETE FROM core_config_data WHERE path = 'web/unsecure/base_url' AND scope <> 'default';
    """
}
