relation sales_order.gift_message_id -> gift_message.gift_message_id
relation sales_order_item.gift_message_id -> gift_message.gift_message_id

relation sales_order.quote_id -> quote.entity_id
relation sales_order.quote_address_id -> quote_address.address_id
relation sales_order_address.quote_address_id -> quote_address.address_id
relation sales_order_item.quote_item_id -> quote_item.item_id
