relation catalog_product_frontend_action.visitor_id -> customer_visitor.visitor_id

relation customer_address_entity.country_id -> directory_country.country_id
relation directory_country_format.country_id -> directory_country.country_id
relation directory_country_region.country_id -> directory_country.country_id
relation quote_address.country_id -> directory_country.country_id
relation sales_order_address.country_id -> directory_country.country_id
