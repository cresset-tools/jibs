relation quote_address.region_id -> directory_country_region.region_id
relation sales_order_address.region_id -> directory_country_region.region_id

relation catalog_category_entity.attribute_set_id -> eav_attribute_set.attribute_set_id
relation catalog_product_entity.attribute_set_id -> eav_attribute_set.attribute_set_id
relation eav_entity.attribute_set_id -> eav_attribute_set.attribute_set_id
relation eav_entity_attribute.attribute_set_id -> eav_attribute_set.attribute_set_id
